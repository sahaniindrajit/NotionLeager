# Server Configuration
PORT=8080                      # Port the HTTP server listens on
ENV=development                # Environment: "development" or "production"

# Telegram Configuration
# Get your bot token from @BotFather on Telegram (https://t.me/BotFather)
# 1. Start a chat with @BotFather
# 2. Send /newbot and follow the prompts
# 3. Copy the token provided
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (only messages from this ID will be processed)
# Get your ID from @userinfobot on Telegram (https://t.me/userinfobot)
TELEGRAM_OWNER_ID=

# Notion Configuration
# 1. Go to https://www.notion.so/my-integrations
# 2. Click "New integration" and give it a name
# 3. Copy the "Internal Integration Token"
NOTION_API_KEY=

# The ID of your Notion database for storing expenses
# 1. Open your expenses database in Notion
# 2. Copy the URL - it looks like: https://notion.so/workspace/DATABASE_ID?v=...
# 3. The DATABASE_ID is the 32-character string before the "?"
# Note: Make sure to connect your integration to this database
#       (click ... menu on database > Connections > Add your integration)
NOTION_EXPENSE_DB_ID=
